---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SITE, I18N, CATEGORIES } from '../config.mjs';
const { post, lang = 'zh' } = Astro.props;
const t = I18N[lang];
const { title, date, cover, coverCaption, price, category } = post.data;
const dateStr = t.dateFmt(date);
const base = lang === 'en' ? '/en' : '';
const catInfo = CATEGORIES[category];
const catName = lang === 'en' ? catInfo.en : catInfo.zh;

// 相关文章:同栏目最新3篇,不足则用其他最新文章补齐
const others = (await getCollection(lang === 'en' ? 'posts-en' : 'posts', ({ data }) => !data.draft))
  .filter((p) => p.slug !== post.slug)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const related = [
  ...others.filter((p) => p.data.category === category),
  ...others.filter((p) => p.data.category !== category),
].slice(0, 3);

const jsonld = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: post.data.description || '',
  datePublished: date.toISOString(),
  inLanguage: lang === 'en' ? 'en' : 'zh-CN',
  articleSection: catInfo.en,
  isAccessibleForFree: !price,
  author: { '@type': 'Person', name: SITE.author },
  publisher: { '@type': 'Organization', name: `${SITE.name} ${SITE.nameEn}`, url: SITE.url },
  mainEntityOfPage: new URL(Astro.url.pathname, SITE.url).href,
  ...(cover ? { image: new URL(cover, SITE.url).href } : {}),
});
---
<BaseLayout title={title} description={post.data.description} lang={lang}>
  <article class="post" data-slug={post.slug} data-title={title} data-lang={lang}>
    <a class="back" href={lang === 'en' ? '/en/' : '/'}>{t.back}</a>
    <div class="post-kicker">
      <span>{SITE.author}</span><span class="dot">/</span><span>{dateStr}</span>
      <span class="dot">/</span><a class="cat-link" href={`${base}/topics/${category}/`}>{catName}</a>
      {price && <span class="dot">/</span>}
      {price && <span class="paid-tag">{t.paidTag(price)}</span>}
    </div>
    <script is:inline type="application/ld+json" set:html={jsonld} />
    <h1 class="post-title">{title}</h1>
    {cover && (
      <figure class="post-cover">
        <img src={cover} alt={title} />
        {coverCaption && <figcaption>{coverCaption}</figcaption>}
      </figure>
    )}
    <div class:list={['post-content', price && 'is-preview']}>
      <slot />
    </div>
    {price && (
      <div class="paywall" id="paywall">
        <p class="paywall-note">{t.paywallNote}</p>
        <button class="btn-gold" id="unlock-btn">{t.unlockBtn(price)}</button>
        <div class="paywall-or"><span>{t.passOr}</span></div>
        <button class="btn-ghost pass-btn">{t.passBtn(SITE.passPrice)}</button>
        <p class="paywall-hint">{t.paywallHint}</p>
      </div>
    )}
    {price && <div class="post-content" id="paid-content" hidden></div>}

    {related.length > 0 && (
      <aside class="related">
        <div class="section-head">{t.related}</div>
        <ul class="related-list">
          {related.map((r) => (
            <li>
              <a href={`${base}/posts/${r.slug}/`}>
                <span class="r-title">{r.data.title}</span>
                <span class="r-date">{t.dateShort(r.data.date)}</span>
              </a>
            </li>
          ))}
        </ul>
      </aside>
    )}

    <div class="tip-card" id="tip-card">
      <div class="tip-head">{t.tipHead}</div>
      <div class="tip-row">
        <button class="tip-btn" data-amount="2">$2</button>
        <button class="tip-btn" data-amount="5">$5</button>
        <button class="tip-btn" data-amount="10">$10</button>
        <span class="tip-custom">
          <span class="cur">$</span>
          <input id="tip-amount" type="number" min="1" max="10000" step="1" placeholder={t.tipCustom} />
          <button class="tip-btn tip-go" id="tip-go">{t.tipGo}</button>
        </span>
      </div>
      <p class="tip-note">{t.tipNote}</p>
    </div>

    <p class="pass-line">
      {t.passLine(SITE.passPrice)}
      <button class="pass-btn pass-link" type="button">{t.passGo}</button>
    </p>

    <p class="pass-line member-line">
      {t.memberLine}
      <a class="pass-link" href={SITE.kofi} target="_blank" rel="noopener noreferrer">{t.memberGo}</a>
    </p>
  </article>
</BaseLayout>

<script>
  const article = document.querySelector('article.post') as HTMLElement;
  const slug = article.dataset.slug || '';
  const title = article.dataset.title || '';
  const isEn = article.dataset.lang === 'en';

  const MSG = isEn
    ? {
        unavailable: 'Payment is temporarily unavailable. Please try again later.',
        minAmount: 'Please enter an amount of $1 or more',
        maxAmount: 'Maximum $10,000 per payment',
        thanks: 'Tip received — thank you for your support',
        unlocked: 'Full article unlocked. Thank you!',
        unlockfail: 'Payment incomplete — the article is still locked',
      }
    : {
        unavailable: '支付通道暂时不可用,请稍后再试',
        minAmount: '请输入 $1 以上的金额',
        maxAmount: '单笔最多 $10,000',
        thanks: '收到你的打赏,谢谢支持',
        unlocked: '已解锁全文,感谢支持',
        unlockfail: '支付未完成,全文尚未解锁',
      };

  function toast(msg: string) {
    const el = document.createElement('div');
    el.className = 'toast';
    el.textContent = msg;
    document.body.appendChild(el);
    requestAnimationFrame(() => el.classList.add('on'));
    setTimeout(() => { el.classList.remove('on'); setTimeout(() => el.remove(), 400); }, 4200);
  }

  async function checkout(payload: object, btn: HTMLButtonElement) {
    btn.disabled = true;
    try {
      const r = await fetch('/api/checkout', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ ...payload, path: location.pathname }),
      });
      const d = await r.json();
      if (r.ok && d.url) { location.href = d.url; return; }
      toast(d.error || MSG.unavailable);
    } catch {
      toast(MSG.unavailable);
    }
    btn.disabled = false;
  }

  document.querySelectorAll<HTMLButtonElement>('.tip-btn[data-amount]').forEach((b) =>
    b.addEventListener('click', () =>
      checkout({ type: 'tip', amount: Number(b.dataset.amount), slug, title }, b)),
  );
  const tipGo = document.getElementById('tip-go') as HTMLButtonElement | null;
  tipGo?.addEventListener('click', () => {
    const v = Number((document.getElementById('tip-amount') as HTMLInputElement).value);
    if (!Number.isFinite(v) || v < 1) { toast(MSG.minAmount); return; }
    if (v > 10000) { toast(MSG.maxAmount); return; }
    checkout({ type: 'tip', amount: v, slug, title }, tipGo);
  });

  const unlockBtn = document.getElementById('unlock-btn') as HTMLButtonElement | null;
  unlockBtn?.addEventListener('click', () => checkout({ type: 'unlock', slug }, unlockBtn));

  document.querySelectorAll<HTMLButtonElement>('.pass-btn').forEach((b) =>
    b.addEventListener('click', () => checkout({ type: 'pass' }, b)),
  );

  // 付费文章:已解锁(cookie 有效)则直接取全文替换付费墙
  if (document.getElementById('paywall')) {
    fetch(`/api/content?slug=${encodeURIComponent(slug)}`)
      .then((r) => (r.ok ? r.json() : null))
      .then((d) => {
        if (d && d.html) {
          const paid = document.getElementById('paid-content')!;
          paid.innerHTML = d.html;
          paid.hidden = false;
          document.getElementById('paywall')?.remove();
          document.querySelector('.post-content.is-preview')?.classList.remove('is-preview');
        }
      })
      .catch(() => {});
  }

  const q = new URLSearchParams(location.search);
  if (q.get('thanks')) toast(MSG.thanks);
  if (q.get('unlocked')) toast(MSG.unlocked);
  if (q.get('unlockfail')) toast(MSG.unlockfail);
</script>
