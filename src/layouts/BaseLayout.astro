---
import { SITE } from '../config.mjs';
import '../styles/global.css';
const { title, description } = Astro.props;
const pageTitle = title ? `${title} · ${SITE.name}` : `${SITE.name} · ${SITE.tagline}`;
const year = new Date().getFullYear();
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;1,9..144,400&family=JetBrains+Mono:wght@400;500&family=Noto+Serif+SC:wght@400;600;700;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="wrap">
      <div class="util-bar">
        <span>独立财经分析 · INDEPENDENT RESEARCH</span>
        <nav class="nav">
          <a href="/">首页</a>
          <a href="/about">关于</a>
          <a href="/contact">联系</a>
        </nav>
      </div>

      <header class="masthead">
        <a href="/">
          <div class="eyebrow">The Critical Point</div>
          <h1 class="name">{SITE.name}</h1>
        </a>
        <div class="rule-row"><span>{SITE.tagline} · {year}</span></div>
      </header>

      <main class="site-main">
        <slot />
      </main>

      <footer class="site-footer">
        <p class="fd">{SITE.disclaimer}</p>
        <nav class="flinks">
          <a href="/about">关于</a>
          <a href="/terms">服务条款</a>
          <a href="/privacy">隐私政策</a>
          <a href="/refunds">退款政策</a>
          <a href="/contact">联系我们</a>
        </nav>
        <p class="fc">© {year} {SITE.author} · {SITE.name} The Critical Point · fncuthdert.com</p>
        <p class="fop">运营者 {SITE.operator} · <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a> · 支付由 Stripe 安全处理</p>
      </footer>
    </div>
  </body>
</html>
