---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../config.mjs';
---
<BaseLayout title="Contact" description="Contact The Critical Point (fncuthdert.com)" lang="en">
  <article class="post">
    <h1 class="post-title">Contact</h1>
    <div class="post-content legal">
      <p>For any questions about payments, unlocking, refunds, or content, email us — we usually reply within <strong>2 business days</strong>:</p>
      <p class="contact-line">📮 <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a></p>
      <ul>
        <li>Site: {SITE.name} · {SITE.nameEn} (fncuthdert.com)</li>
        <li>Operator: {SITE.operator}</li>
        <li>For payment issues, please include the transaction ID from your Stripe receipt so we can locate it quickly.</li>
      </ul>
      <p>Business inquiries and republication requests: same email.</p>
    </div>
  </article>
</BaseLayout>
