---
import { getCollection } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { splitBody, renderMd } from '../../lib/paywall.mjs';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const isPaid = !!post.data.price;
// 付费文章:静态页只渲染前2段预览,其余正文由 /api/content 验证后下发
const previewHtml = isPaid ? renderMd(splitBody(post.body).previewMd) : '';
const Content = isPaid ? null : (await post.render()).Content;
---
<PostLayout post={post}>
  {isPaid ? <Fragment set:html={previewHtml} /> : <Content />}
</PostLayout>
